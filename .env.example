# ---- LLM ----
# OpenAI API key — used by the AI SDK OpenAI provider (model: gpt-4.1)
OPENAI_API_KEY=sk-...

# ---- Web search ----
# Tavily API key — powers the web_search tool (https://tavily.com)
TAVILY_API_KEY=tvly-...

# ---- Database ----
# Local MongoDB (start it with: brew services start mongodb-community)
MONGODB_URI=mongodb://127.0.0.1:27017/scout

# ---- Auth ----
# Secret used to sign session JWTs. Use a long, random string in production.
JWT_SECRET=change-me-to-a-long-random-string
